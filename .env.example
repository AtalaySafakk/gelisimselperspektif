# App
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/yilmazer?schema=public

# Auth (min 32 chars)
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars!!
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars!
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d
# Access: 15m önerilir — JWT_ACCESS_EXPIRES=15m

# Cloudflare R2 (optional until upload features)
# Tarayıcıdan presigned PUT için: R2 bucket → Settings → CORS:
# Allowed origins: http://localhost:3000 ve canlı site URL’niz
# Allowed methods: GET, PUT, HEAD  |  Allowed headers: Content-Type (veya *)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com

# Providers
VIDEO_PROVIDER=manual
PAYMENT_PROVIDER=manual
DEFAULT_PLATFORM_FEE_PERCENT=20

# Encryption (optional)
ENCRYPTION_KEY=change-me-encryption-key-min-32-chars!!
