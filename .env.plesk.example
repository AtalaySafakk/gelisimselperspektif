# Plesk httpdocs/.env — bu dosyayı KOPYALAYIP ".env" adıyla kaydedin (Git'e pushlamayın).
# Custom environment variables + bu dosya ikisi de olsun (site + npm run plesk:setup).

NODE_ENV=production
NEXT_PUBLIC_APP_URL=https://gelisimselperspektif.com

DATABASE_URL=postgresql://DB_KULLANICI:DB_SIFRE@localhost:5432/DB_ADI?schema=public

JWT_ACCESS_SECRET=EN_AZ_32_KARAKTER_RASTGELE
JWT_REFRESH_SECRET=BASKA_EN_AZ_32_KARAKTER_RASTGELE
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

PAYMENT_PROVIDER=manual
VIDEO_PROVIDER=manual

# R2 (dekont/belge/slider) — hazırsanız doldurun
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=
# R2_ENDPOINT=https://HESAP_ID.r2.cloudflarestorage.com
